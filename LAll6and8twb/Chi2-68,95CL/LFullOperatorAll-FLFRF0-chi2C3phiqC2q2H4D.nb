Cell[BoxData[
 RowBox[{
  RowBox[{"shiftedChi2", "[", 
   RowBox[{"c1_", ",", "ct_"}], "]"}], ":=", 
  RowBox[{"Chi2", "[", 
   RowBox[{
    RowBox[{"c1", "+", 
     RowBox[{"bestFit", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "2"}], "]"}], "]"}]}], ",", 
