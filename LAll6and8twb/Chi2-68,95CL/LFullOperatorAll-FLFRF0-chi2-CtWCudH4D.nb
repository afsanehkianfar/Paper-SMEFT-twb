Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"contour", "=", 
   RowBox[{"ContourPlot", "[", 
    RowBox[{
     RowBox[{"Chi2", "[", 
      RowBox[{
      "CtW", ",", "CbW", ",", "C3phiq", ",", "CHud", ",", "C1quWH3", ",", 
       "C1qdWH3", ",", "C2q2H4D", ",", "C3q2H4D", ",", "CudH4D"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"CtW", ",", 
       RowBox[{"-", "50"}], ",", "50"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"C1quWH3", ",", 
       RowBox[{"-", "100"}], ",", "100"}], "}"}], ",", 
     RowBox[{"Contours", "->", 
      RowBox[{"{", 
       RowBox[{"chi2min", "+", "deltaChi2"}], "}"}]}], ",", 
     RowBox[{"ContourStyle", "->", 
      RowBox[{"{", 
       RowBox[{"Thick", ",", "Purple"}], "}"}]}], ",", 
     RowBox[{"PlotPoints", "->", "100"}], ",", 
     RowBox[{"Frame", "->", "False"}], ",", 
     RowBox[{"Axes", "->", "False"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"contour3D", "=", 
   RowBox[{"Graphics3D", "[", 
    RowBox[{"Cases", "[", 
     RowBox[{
      RowBox[{"Normal", "[", "contour", "]"}], ",", 
      RowBox[{
       RowBox[{"Line", "[", "pts_", "]"}], ":>", 
       RowBox[{"Line", "[", 
        RowBox[{"pts", "/.", " ", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"x_", ",", "y_"}], "}"}], ":>", 
          RowBox[{"{", 
           RowBox[{"x", ",", "y", ",", 
            RowBox[{"chi2min", "+", "deltaChi2"}]}], "}"}]}]}], "]"}]}], ",", 
      "Infinity"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"Show", "[", 
  RowBox[{"plot3d", ",", "curve1", ",", "curve2", ",", "contour3D", ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"Boxed", "->", "True"}], ",", 
   RowBox[{"AspectRatio", "->", "1"}]}], "]"}], "\n"}], "Input",
 CellChangeTimes->{{3.962848104529285*^9, 3.9628481180531683`*^9}, {
